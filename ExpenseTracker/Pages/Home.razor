@page "/"
@inject IExpenseStorageService StorageService

<PageTitle>Expense Tracker</PageTitle>

<div class="app-shell container-fluid px-2 px-md-3">

    <nav class="tab-nav">
        <button class="@(ActiveTab == AppTab.Records ? "active" : null)" @onclick="() => ActiveTab = AppTab.Records">
            <i class="fa-solid fa-list"></i>
            <span>Records</span>
        </button>
        <button class="@(ActiveTab == AppTab.Analytics ? "active" : null)" @onclick="() => ActiveTab = AppTab.Analytics">
            <i class="fa-solid fa-chart-pie"></i>
            <span>Analytics</span>
        </button>
        <button class="@(ActiveTab == AppTab.Settings ? "active" : null)" @onclick="() => ActiveTab = AppTab.Settings">
            <i class="fa-solid fa-gear"></i>
            <span>Settings</span>
        </button>
    </nav>

    @if (ActiveTab == AppTab.Records)
    {
        <RecordsTab Records="Records" OnCreate="OpenCreate" OnSelect="OpenEdit" />
    }
    else if (ActiveTab == AppTab.Analytics)
    {
        <AnalyticsTab Records="Records" />
    }
    else
    {
        <SettingsTab OnDataChanged="ReloadRecordsAsync" />
    }
</div>

<ExpenseEditorPanel
    Show="ShowEditor"
    Record="EditingRecord"
    OnSave="SaveRecord"
    OnClose="CloseEditor" />

@code {
    private enum AppTab { Records, Analytics, Settings }

    private List<ExpenseRecord> Records { get; set; } = [];
    private ExpenseRecord EditingRecord { get; set; } = new() { Id = Guid.Empty };
    private AppTab ActiveTab { get; set; } = AppTab.Records;
    private bool ShowEditor { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await ReloadRecordsAsync();
    }

    private async Task ReloadRecordsAsync()
    {
        Records = (await StorageService.GetAllAsync()).OrderByDescending(r => r.CreatedAt).ToList();
        StateHasChanged();
    }

    private void OpenCreate()
    {
        EditingRecord = new ExpenseRecord { Id = Guid.Empty, CreatedAt = DateTime.UtcNow };
        ShowEditor = true;
    }

    private void OpenEdit(ExpenseRecord item)
    {
        EditingRecord = new ExpenseRecord
        {
            Id = item.Id,
            Amount = item.Amount,
            Category = item.Category,
            CreatedAt = item.CreatedAt,
            Note = item.Note,
            ReceiptDataUrl = item.ReceiptDataUrl,
            ReceiptFileName = item.ReceiptFileName
        };
        ShowEditor = true;
    }

    private async Task SaveRecord(ExpenseRecord record)
    {
        await StorageService.UpsertAsync(record);
        await ReloadRecordsAsync();
        CloseEditor();
    }

    private void CloseEditor() => ShowEditor = false;
}
